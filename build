#!/usr/bin/env bash
# Build the Jumbee.Console TestDemo (and its dependency chain: core, Styles, VtNetCore, …).
# Extra args are passed through to `dotnet build`, e.g. ./build -c Release
set -euo pipefail
cd "$(dirname "$0")"
exec dotnet build tests/Jumbee.Console.TestDemo/Jumbee.Console.TestDemo.csproj -c Debug "$@"
