classDiagram
  class Shape {
    <<abstract>>
    +String name
    #Color fill
    +area() double
    +draw() void
  }
  class Circle {
    -double radius
    +area() double
  }
  class Rectangle {
    -double width
    -double height
    +area() double
  }
  class Canvas {
    -List~Shape~ shapes
    +add(Shape s) void
    +render() void
  }
  Shape <|-- Circle
  Shape <|-- Rectangle
  Canvas "1" o-- "*" Shape : contains
