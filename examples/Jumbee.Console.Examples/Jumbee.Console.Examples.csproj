<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Jumbee.Console.Documents\Jumbee.Console.Documents.csproj" />
    <ProjectReference Include="..\..\src\Jumbee.Console\Jumbee.Console.csproj" />
</ItemGroup>

  <!-- Embed each example's own source so the browser's right pane can show exactly what compiled. The files stay
       Compile items too (a file may be both), and embedded resources work under PublishAot. -->
  <ItemGroup>
    <EmbeddedResource Include="Examples\**\*.cs" />
    <EmbeddedResource Include="Examples\**\*.md" />
    <EmbeddedResource Include="Examples\**\*.adoc" />
    <EmbeddedResource Include="Examples\**\*.mmd" />
  </ItemGroup>

  <!-- Also embed the source of the library controls/layouts the examples derive from, so the viewer can show a
       "base control" source tab beside the example (see IExample.SourceFiles). Linked with a folder prefix so each
       resource name still ends with ".<File>.cs" for SourceLoader's suffix match. Not compiled here (resource only). -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\src\Jumbee.Console\Controls\**\*.cs" Link="ControlSource\%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console\Layouts\**\*.cs" Link="LayoutSource\%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console\SpectreControl.cs" Link="ControlSource\SpectreControl.cs" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console.Styles\ButtonStyle.cs" Link="ControlSource\ButtonStyle.cs" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console.Documents\AsciiDoc\AsciiDocViewer.cs" Link="ControlSource\AsciiDocViewer.cs" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console.Documents\AsciiDoc\InteractiveAsciiDocEditor.cs" Link="ControlSource\InteractiveAsciiDocEditor.cs" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console.Documents\Markdown\InteractiveMarkdownExtendedEditor.cs" Link="ControlSource\InteractiveMarkdownExtendedEditor.cs" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console.Documents\Markdown\MarkdownExtendedViewer.cs" Link="ControlSource\MarkdownExtendedViewer.cs" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console.Documents\Mermaid\InteractiveMermaidEditor.cs" Link="ControlSource\InteractiveMermaidEditor.cs" />
    <EmbeddedResource Include="..\..\src\Jumbee.Console.Documents\Mermaid\MermaidViewer.cs" Link="ControlSource\MermaidViewer.cs" />
  </ItemGroup>

  <!-- Embed an internal design doc as the sample content for the Markdown Viewer example (rendered live in the pane,
       and shown as a "Input.md" source tab beside it). The resource name ends with ".Input.md" for SourceLoader. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\docs\internal\Input.md" Link="DocSource\Input.md" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Examples\Viewers\" />
  </ItemGroup>

</Project>
