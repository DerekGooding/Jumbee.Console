<Project Sdk="Microsoft.NET.Sdk">
  <!-- Forked/vendored (ext/) + own Styles references, all PrivateAssets="all" so none become NuGet dependencies;
       this package BUNDLES their DLLs into lib/ instead (see _AddBundledAssembliesToPackage). The same file is
       imported by the add-on/example/test projects so they can compile against these types too. -->
  <Import Project="..\ExternalReferences.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyVersion>$(ProjectAssemblyVersion)</AssemblyVersion>
    <FileVersion>$(ProjectAssemblyVersion)</FileVersion>
    <Version>$(ProjectAssemblyVersion)</Version>
  </PropertyGroup>

  <!-- NuGet packaging. This is the self-contained core package: it BUNDLES the forked/vendored assemblies under
       ext/ (Spectre.Console, ConsoleGUI, ConsolePlot, VtNetCore, NTokenizers.Extensions, RazorConsole + ColorCode)
       and our own Jumbee.Console.Styles into lib/, because none of those are published on NuGet. Only genuine
       PackageReferences (see NTokenizers below) become NuGet dependencies. -->
  <PropertyGroup Label="Packaging">
    <IsPackable>true</IsPackable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>A .NET library for retained-mode terminal user interfaces (TUIs) that focuses on performance and ease-of-use.</Description>
    <!-- Inject the bundled assemblies into the package's lib/ folder. -->
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);_AddBundledAssembliesToPackage</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>

  <!-- Genuine NuGet dependency: pulled in transitively by the bundled NTokenizers.Extensions.Spectre.Console. It
       IS published on nuget.org, so consumers restore it normally rather than us bundling its assemblies. -->
  <ItemGroup>
    <PackageReference Include="NTokenizers" Version="6.1.1" />
  </ItemGroup>

  <!-- Ship this package's README (shown on nuget.org) and the third-party licence notices for the bundled assemblies. -->
  <ItemGroup>
    <None Include="..\..\package\README.md" Pack="true" PackagePath="\" Visible="false" />
    <None Include="..\..\THIRD-PARTY-NOTICES.TXT" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

  <!-- Copy the private (fork/vendored/own) project-reference assemblies + their XML docs into lib/. NuGet-sourced
       assemblies (NuGetPackageId set, e.g. NTokenizers) are excluded — they stay as restored dependencies. -->
  <Target Name="_AddBundledAssembliesToPackage" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <!-- The private project-reference DLLs. -->
      <_BundledDll Include="@(ReferenceCopyLocalPaths)"
        Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference' and '%(Extension)' == '.dll'" />
      <!-- Their sibling XML docs, when the project emits one (some forks don't). We derive these from each bundled
           DLL's path rather than matching '.xml' in ReferenceCopyLocalPaths directly: the XML doc copies there do
           NOT carry ReferenceSourceTarget='ProjectReference', so the old condition silently shipped zero XML — which
           left the bundled Styles/Spectre/etc. APIs with no IntelliSense for consumers. -->
      <_BundledXml Include="@(_BundledDll->'%(RootDir)%(Directory)%(Filename).xml')"
        Condition="Exists('%(RootDir)%(Directory)%(Filename).xml')" />
      <BuildOutputInPackage Include="@(_BundledDll);@(_BundledXml)" />
    </ItemGroup>
    <Message Importance="normal" Text="Jumbee.Console pack: bundled @(_BundledDll->Count()) private assemblies + @(_BundledXml->Count()) XML docs into lib/." />
  </Target>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <IsTrimmable>True</IsTrimmable>
    <IsAotCompatible>True</IsAotCompatible>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <IsTrimmable>True</IsTrimmable>
    <IsAotCompatible>True</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Jumbee.Console.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Coastline POINT CLOUDS, scatter-plotted by the Canvas WorldMap shape. -->
    <EmbeddedResource Include="Geo\world_low.txt" />
    <EmbeddedResource Include="Geo\world_high.txt" />
    <!-- Land POLYGONS (closed rings), filled by the Globe's EarthMask. -->
    <EmbeddedResource Include="Geo\land_110m.txt" />
    <!-- Public-domain NASA Blue Marble natural-colour texture (256x128, 8-byte header + raw RGB), sampled by the
         Globe's EarthTexture for the from-space land/ocean colouring. Regenerate at any resolution with the
         GLOBE_TEXTURE_TOOL baker in Globe.cs. See THIRD-PARTY-NOTICES.TXT. -->
    <EmbeddedResource Include="Geo\earth_256x128.bin" />
  </ItemGroup>

</Project>
