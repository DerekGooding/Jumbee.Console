{
  "version": "0.2.0",
  "configurations": [
    {
      // Debug the TerminalEmulator demo. Builds first, then launches in the integrated terminal — required
      // because the demo is a full-screen VT/TUI app and won't render in VS Code's Debug Console.
      "name": "Debug TestDemo (TerminalEmulator)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-testdemo",
      "program": "${workspaceFolder}/tests/Jumbee.Console.TestDemo/bin/Debug/net10.0/Jumbee.Console.TestDemo.dll",
      "args": ["/bin/bash"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    }
  ]
}
